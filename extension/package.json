{
  "name": "owlvex",
  "displayName": "Owlvex",
  "description": "Scan your code against OWASP, STRIDE, MITRE, CWE and Clean Code using your own AI",
  "version": "0.1.43",
  "publisher": "owlvex",
  "repository": {
    "type": "git",
    "url": "https://github.com/owlvex/owlvex.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "owlvex.scanFile",
        "title": "Owlvex: Scan Current File"
      },
      {
        "command": "owlvex.scanSelectedFiles",
        "title": "Owlvex: Scan Selected Files"
      },
      {
        "command": "owlvex.scanChangedFiles",
        "title": "Owlvex: Scan Changed Files"
      },
      {
        "command": "owlvex.scanGitTarget",
        "title": "Owlvex: Scan Git Commit or Range"
      },
      {
        "command": "owlvex.scanOpenEditors",
        "title": "Owlvex: Scan Open Editors"
      },
      {
        "command": "owlvex.scanWorkspace",
        "title": "Owlvex: Scan Workspace"
      },
      {
        "command": "owlvex.scanWorkspaceReport",
        "title": "Owlvex: Create Report"
      },
      {
        "command": "owlvex.selectFrameworks",
        "title": "Owlvex: Select Frameworks"
      },
      {
        "command": "owlvex.openPromptEditor",
        "title": "Owlvex: Open AI Chat"
      },
      {
        "command": "owlvex.switchModel",
        "title": "Owlvex: Switch AI Model"
      },
      {
        "command": "owlvex.configureProviderThrottling",
        "title": "Owlvex: Configure Provider Throttling"
      },
      {
        "command": "owlvex.setupAI",
        "title": "Owlvex: Setup AI Connection"
      },
      {
        "command": "owlvex.configureBackend",
        "title": "Owlvex: Configure Backend Override URL"
      },
      {
        "command": "owlvex.removeAIConnection",
        "title": "Owlvex: Remove AI Connection"
      },
      {
        "command": "owlvex.openProjectContext",
        "title": "Owlvex: Open Project Context"
      },
      {
        "command": "owlvex.openTddBox",
        "title": "Owlvex: Open TDD Box"
      },
      {
        "command": "owlvex.openDesignContext",
        "title": "Owlvex: Open Design Context"
      },
      {
        "command": "owlvex.createDesignMap",
        "title": "Owlvex: Create Design Map"
      },
      {
        "command": "owlvex.openDesignMap",
        "title": "Owlvex: Open Design Map"
      },
      {
        "command": "owlvex.openDriftBox",
        "title": "Owlvex: Open Drift Box"
      },
      {
        "command": "owlvex.testAIConnection",
        "title": "Owlvex: Test AI Connection"
      },
      {
        "command": "owlvex.testTrialSetup",
        "title": "Owlvex: Test Trial Setup"
      },
      {
        "command": "owlvex.showOnboarding",
        "title": "Owlvex: Show Onboarding"
      },
      {
        "command": "owlvex.selectProjectRoot",
        "title": "Owlvex: Select Project Root"
      },
      {
        "command": "owlvex.enterLicence",
        "title": "Owlvex: Enter Licence Key"
      },
      {
        "command": "owlvex.removeLicence",
        "title": "Owlvex: Remove Licence Key"
      },
      {
        "command": "owlvex.toggleTelemetry",
        "title": "Owlvex: Toggle Product Telemetry"
      },
      {
        "command": "owlvex.registerAccess",
        "title": "Owlvex: Register Free Or Trial Access"
      },
      {
        "command": "owlvex.compareScans",
        "title": "Owlvex: Compare Reports"
      },
      {
        "command": "owlvex.compareLatestReports",
        "title": "Owlvex: Compare Last 2 Reports"
      },
      {
        "command": "owlvex.reviewRiskCalibration",
        "title": "Owlvex: Review Risk Calibration"
      },
      {
        "command": "owlvex.discussFinding",
        "title": "Owlvex: Discuss Finding"
      },
      {
        "command": "owlvex.generateFixPreview",
        "title": "Owlvex: Review Fix"
      },
      {
        "command": "owlvex.applyFixPreview",
        "title": "Owlvex: Apply Fix Preview"
      }
    ],
    "configuration": {
      "title": "Owlvex",
      "properties": {
        "owlvex.apiUrl": {
          "type": "string",
          "default": "https://owlvex-api.azurewebsites.net",
          "description": "Owlvex backend API URL"
        },
        "owlvex.provider": {
          "type": "string",
          "enum": [
            "azure-foundry",
            "anthropic",
            "openai",
            "mistral",
            "gemini",
            "groq",
            "ollama",
            "custom"
          ],
          "default": "openai",
          "description": "AI provider to use for scanning"
        },
        "owlvex.foundry.endpoint": {
          "type": "string",
          "default": "",
          "description": "Azure AI Foundry endpoint URL"
        },
        "owlvex.foundry.model": {
          "type": "string",
          "default": "",
          "description": "Azure AI Foundry deployment name to use for chat completions"
        },
        "owlvex.foundry.deployments": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Known Azure AI Foundry deployment names shown in the model picker"
        },
        "owlvex.openai.model": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Default OpenAI model"
        },
        "owlvex.anthropic.model": {
          "type": "string",
          "default": "claude-opus-4-6",
          "description": "Default Anthropic model"
        },
        "owlvex.ollama.host": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama host URL"
        },
        "owlvex.ollama.model": {
          "type": "string",
          "default": "qwen2.5:7b",
          "description": "Default Ollama model"
        },
        "owlvex.custom.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Custom OpenAI-compatible endpoint base URL"
        },
        "owlvex.custom.model": {
          "type": "string",
          "default": "",
          "description": "Model name for custom endpoint"
        },
        "owlvex.mistral.model": {
          "type": "string",
          "default": "mistral-large-latest",
          "description": "Default Mistral model"
        },
        "owlvex.gemini.model": {
          "type": "string",
          "default": "gemini-1.5-pro",
          "description": "Default Gemini model"
        },
        "owlvex.groq.model": {
          "type": "string",
          "default": "llama-3.3-70b-versatile",
          "description": "Default Groq model"
        },
        "owlvex.frameworks": {
          "type": "array",
          "default": [
            "OWASP",
            "STRIDE"
          ],
          "description": "Security frameworks to scan against"
        },
        "owlvex.scanOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically scan file on save"
        },
        "owlvex.severityThreshold": {
          "type": "string",
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH",
            "CRITICAL"
          ],
          "default": "MEDIUM",
          "description": "Minimum severity to display"
        },
        "owlvex.teamContext": {
          "type": "string",
          "default": "",
          "description": "Legacy optional project/team context appended to prompts. Prefer owlvex.projectContext or owlvex.projectContextFile."
        },
        "owlvex.projectContext": {
          "type": "string",
          "default": "",
          "description": "Optional local project context contract or TDD-style summary used to ground AI scans and remediation prompts"
        },
        "owlvex.projectContextFile": {
          "type": "string",
          "default": "",
          "description": "Optional local file path to a project context contract document used to ground AI scans and remediation prompts"
        },
        "owlvex.tddBoxEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Include the configured local TDD/project context file during scans. This is workflow context, not a security framework."
        },
        "owlvex.designContextFile": {
          "type": "string",
          "default": "",
          "description": "Optional local file path to the Design Box context document used to ground architecture, STRIDE, trust-boundary, role, and data-flow reasoning. Supports markdown/text, DOCX, and best-effort PDF text extraction"
        },
        "owlvex.designMapEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Use the local Owlvex-generated Design Map when available to ground repo-aware chat, scan, report, and fix reasoning. The map is stored under the selected project root and is never uploaded to the Owlvex backend."
        },
        "owlvex.driftBoxFile": {
          "type": "string",
          "default": "",
          "description": "Optional local file path to the Drift Box JSON config. Defaults to .owlvex/drift/owlvex-drift.json under the selected project root"
        },
        "owlvex.driftScriptsRoot": {
          "type": "string",
          "default": "",
          "description": "Optional local folder that contains Drift Box scripts. Defaults to .owlvex/drift/scripts under the selected project root"
        },
        "owlvex.driftBoxEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Run configured Drift Box behavior checks during scans and post-fix verification. Drift Box is report-only and is not a security framework."
        },
        "owlvex.projectRoot": {
          "type": "string",
          "default": "",
          "description": "Repo root Owlvex should treat as the active project boundary for workspace scans and repo-wide AI context"
        },
        "owlvex.providerThrottleOverrides": {
          "type": "object",
          "default": {},
          "markdownDescription": "Advanced per-provider throttling overrides. Azure AI Foundry is paced by default because captured reports showed real 429s; other providers run loose unless you add an override. Keys are provider ids such as `azure-foundry`, `openai`, `anthropic`, `gemini`, `groq`, `mistral`, `custom`, or `default`. Each value can override `maxConcurrent`, `minSpacingMs`, `baseBackoffMs`, `maxBackoffMs`, and `retryAttempts`. Example: `{ \"azure-foundry\": { \"maxConcurrent\": 1, \"minSpacingMs\": 7000, \"retryAttempts\": 2 }, \"openai\": { \"maxConcurrent\": 1 } }`."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "owlvex",
          "title": "Owlvex",
          "icon": "media/owlvex-prod.svg"
        }
      ]
    },
    "views": {
      "owlvex": [
        {
          "id": "owlvex.findings",
          "name": "Security Findings"
        },
        {
          "id": "owlvex.chat",
          "name": "AI Chat",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "owlvex.scanFile",
          "when": "resourceScheme == file",
          "group": "navigation@50"
        },
        {
          "command": "owlvex.scanSelectedFiles",
          "when": "resourceScheme == file",
          "group": "navigation@51"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run package:prod",
    "package:prod": "node ./scripts/package-profile.mjs prod",
    "package:dev": "node ./scripts/package-profile.mjs dev",
    "package:all": "npm run package:dev && npm run package:prod",
    "package:verify": "node ./scripts/verify-packages.mjs",
    "test:regression": "npm run compile && jest --runInBand --runTestsByPath src/panels/chatViewProvider.test.ts src/panels/sidebarProvider.test.ts src/scanner/deterministicScanner.test.ts src/scanner/reportGenerator.test.ts src/scanner/engineEvidenceRegression.test.ts src/ui/statusBar.test.ts src/packageProfile.test.ts && npm run benchmark:proof-contracts && npm run benchmark:evaluator-tests",
    "test:release": "npm run test:regression && npm run package:all && npm run package:verify",
    "publish:prod": "npm run test:release && npx @vscode/vsce publish --packagePath dist/owlvex-prod.vsix",
    "publish:dev": "npm run package:dev && npx @vscode/vsce publish --packagePath dist/owlvex-dev.vsix",
    "lint": "eslint src --ext ts",
    "test": "jest --coverage",
    "corpus:test": "npm run compile && node ./out/frameworks/corpusRunner.js",
    "benchmark:import": "node ../tools/owlvex-benchmark/import-report.mjs",
    "benchmark:ai-evals": "node ../tools/owlvex-benchmark/run-ai-evals.mjs",
    "benchmark:ai-status": "node ../tools/owlvex-benchmark/ai-eval-status.mjs",
    "benchmark:run:ssh": "node ../tools/owlvex-benchmark/run-ollama-ssh.mjs",
    "benchmark:score": "node ../tools/owlvex-benchmark/score.mjs",
    "benchmark:gr001": "node ../tools/owlvex-benchmark/engine/gr001/run-gr001-corpus.mjs",
    "benchmark:gr002": "node ../tools/owlvex-benchmark/engine/gr002/run-gr002-corpus.mjs",
    "benchmark:gr003": "node ../tools/owlvex-benchmark/engine/gr003/run-gr003-corpus.mjs",
    "benchmark:gr004": "node ../tools/owlvex-benchmark/engine/gr004/run-gr004-corpus.mjs",
    "benchmark:gr005": "node ../tools/owlvex-benchmark/engine/gr005/run-gr005-corpus.mjs",
    "benchmark:integration": "node ../tools/owlvex-benchmark/engine/execution-risk-integration/run-execution-risk-integration.mjs",
    "benchmark:proof-contracts": "node ../tools/owlvex-benchmark/engine/proof-contracts/run-proof-contracts.mjs",
    "benchmark:deterministic": "node ../tools/owlvex-benchmark/run-deterministic.mjs",
    "benchmark:status": "node ../tools/owlvex-benchmark/benchmark-status.mjs",
    "benchmark:metrics": "node ../tools/owlvex-benchmark/benchmark-metrics.mjs",
    "release:check": "node ../tools/release-check.mjs",
    "benchmark:stabilization": "node ../tools/run-stabilization-benchmark.mjs",
    "benchmark:generate-reports": "npm run compile && node ./scripts/generate-stabilization-reports.mjs",
    "benchmark:refresh-and-evaluate": "npm run benchmark:generate-reports && npm run benchmark:stabilization:demo && npm run benchmark:stabilization:benchmark-app",
    "benchmark:ai-demo": "node ../tools/evaluate-ai-benchmark.mjs",
    "benchmark:fix-demo": "node ../tools/evaluate-fix-benchmark.mjs",
    "benchmark:stabilization:demo": "node ../tools/evaluate-stabilization-report.mjs demo",
    "benchmark:stabilization:benchmark-app": "node ../tools/evaluate-stabilization-report.mjs benchmark-app",
    "benchmark:evaluator-tests": "node ../tools/test-stabilization-evaluator.mjs",
    "benchmark:compare-reports": "node ../tools/compare-stabilization-evals.mjs",
    "benchmark:sq001": "node ../tools/owlvex-benchmark/engine/sq001/run-sq001-corpus.mjs",
    "benchmark:sq002": "node ../tools/owlvex-benchmark/engine/sq002/run-sq002-corpus.mjs",
    "benchmark:sq003": "node ../tools/owlvex-benchmark/engine/sq003/run-sq003-corpus.mjs",
    "benchmark:sq004": "node ../tools/owlvex-benchmark/engine/sq004/run-sq004-corpus.mjs",
    "benchmark:sq005": "node ../tools/owlvex-benchmark/engine/sq005/run-sq005-corpus.mjs",
    "benchmark:sql-integration": "node ../tools/owlvex-benchmark/engine/sql-query-integration/run-sql-integration.mjs",
    "benchmark:ac001": "node ../tools/owlvex-benchmark/engine/ac001/run-ac001-corpus.mjs",
    "benchmark:ac002": "node ../tools/owlvex-benchmark/engine/ac002/run-ac002-corpus.mjs",
    "benchmark:ac003": "node ../tools/owlvex-benchmark/engine/ac003/run-ac003-corpus.mjs",
    "benchmark:ac004": "node ../tools/owlvex-benchmark/engine/ac004/run-ac004-corpus.mjs",
    "benchmark:ac005": "node ../tools/owlvex-benchmark/engine/ac005/run-ac005-corpus.mjs",
    "benchmark:ac-integration": "node ../tools/owlvex-benchmark/engine/access-control-integration/run-access-control-integration.mjs",
    "benchmark:sm002": "node ../tools/owlvex-benchmark/engine/sm002/run-sm002-corpus.mjs",
    "demo:report": "npm run compile && node ./scripts/generate-demo-report.mjs"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^vscode$": "<rootDir>/src/__mocks__/vscode.ts"
    },
    "modulePathIgnorePatterns": [
      "<rootDir>/out/"
    ],
    "testMatch": [
      "**/src/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/__mocks__/**"
    ]
  }
}
