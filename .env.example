# ============================================================
# .env.example  — commit this file; copy to .env and fill in
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=owlvex
POSTGRES_USER=owlvex_app
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# --- FastAPI ---
SECRET_KEY=CHANGE_ME_32_chars_minimum_secret
ADMIN_KEY=CHANGE_ME_admin_key_for_licence_generation
ENVIRONMENT=development

# --- Stripe (use test-mode keys on ml30) ---
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# --- Stripe Price IDs (from your Stripe dashboard) ---
STRIPE_PRICE_DEVELOPER_MONTHLY=price_CHANGE_ME
STRIPE_PRICE_DEVELOPER_ANNUAL=price_CHANGE_ME
STRIPE_PRICE_TEAM_MONTHLY=price_CHANGE_ME
STRIPE_PRICE_TEAM_ANNUAL=price_CHANGE_ME

# --- Email (for licence key delivery) ---
# Leave blank to skip email sending in dev; key is printed to logs instead
SENDGRID_API_KEY=
FROM_EMAIL=noreply@owlvex.io
