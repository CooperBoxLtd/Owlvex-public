# Secrets — never commit
.env
infra/.env.azure
infra/.env.dev
infra/.env.prod

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/

# Node / Extension
node_modules/
extension/out/
extension/coverage/
extension/*.vsix
extension/.vscode-test/

# Docker build cache artefacts
*.tar

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/

# Unrelated temporary web/php artefacts
tmp/*.html
tmp/*.php
tmp/*.zip
tmp/*.mjs

# Owlvex benchmark run artifacts
tools/owlvex-benchmark/runs/deterministic/*.json
tools/owlvex-benchmark/runs/*.results.json

# Generated Owlvex scan reports
**/owlvex-scan-report-*.md
**/owlvex-summary-report-*.md
