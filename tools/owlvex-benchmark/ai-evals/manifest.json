{
  "version": 1,
  "suite": "owlvex-ai-evals",
  "description": "Lightweight AI-only evaluation lane for issue classes outside the deterministic gate.",
  "cases": [
    {
      "id": "ai-open-redirect-unsafe",
      "file": "tools/demo/16-open-redirect-unsafe.js",
      "expected": {
        "verdict": "ai-finding",
        "preferred_issue_ids": ["owlvex.issue.open_redirect.001"],
        "preferred_provenance": "ai"
      }
    },
    {
      "id": "ai-open-redirect-safe",
      "file": "tools/demo/17-open-redirect-safe.js",
      "expected": {
        "verdict": "clean-or-advisory",
        "must_not_include_issue_ids": ["owlvex.issue.open_redirect.001"]
      }
    },
    {
      "id": "ai-csrf-unsafe",
      "file": "tools/demo/18-csrf-unsafe.js",
      "expected": {
        "verdict": "ai-finding",
        "preferred_issue_ids": ["owlvex.issue.csrf_missing_token.001"],
        "preferred_provenance": "ai"
      }
    },
    {
      "id": "ai-csrf-safe",
      "file": "tools/demo/19-csrf-safe.js",
      "expected": {
        "verdict": "clean-or-advisory",
        "must_not_include_issue_ids": ["owlvex.issue.csrf_missing_token.001"]
      }
    },
    {
      "id": "ai-cors-unsafe",
      "file": "tools/demo/20-cors-unsafe.js",
      "expected": {
        "verdict": "ai-finding",
        "preferred_labels": ["cors", "cross origin resource sharing"],
        "preferred_provenance": "ai",
        "must_include_text": ["review the effective browser and api behavior"],
        "must_not_include_text": ["confirmed data-exfiltration path"]
      }
    },
    {
      "id": "ai-cors-safe",
      "file": "tools/demo/21-cors-safe.js",
      "expected": {
        "verdict": "clean-or-advisory",
        "must_not_include_labels": ["cors misconfiguration", "overly permissive cors"]
      }
    },
    {
      "id": "ai-ssrf-unsafe",
      "file": "tools/demo/22-ssrf-unsafe.js",
      "expected": {
        "verdict": "ai-finding",
        "preferred_issue_ids": ["owlvex.issue.ssrf.001"],
        "preferred_provenance": "ai"
      }
    },
    {
      "id": "ai-ssrf-safe",
      "file": "tools/demo/23-ssrf-safe.js",
      "expected": {
        "verdict": "clean-or-advisory",
        "must_not_include_issue_ids": ["owlvex.issue.ssrf.001"]
      }
    },
    {
      "id": "ai-jwt-validation-unsafe",
      "file": "tools/demo/24-jwt-validation-unsafe.js",
      "expected": {
        "verdict": "ai-finding",
        "preferred_issue_ids": ["owlvex.issue.weak_jwt_validation.001"],
        "preferred_provenance": "ai"
      }
    },
    {
      "id": "ai-jwt-validation-safe",
      "file": "tools/demo/25-jwt-validation-safe.js",
      "expected": {
        "verdict": "clean-or-advisory",
        "must_not_include_issue_ids": ["owlvex.issue.weak_jwt_validation.001"]
      }
    },
    {
      "id": "ai-deserialization-unsafe",
      "file": "tools/demo/26-deserialization-unsafe.py",
      "expected": {
        "verdict": "ai-finding",
        "preferred_issue_ids": ["owlvex.issue.insecure_deserialization.001"],
        "preferred_provenance": "ai"
      }
    },
    {
      "id": "ai-deserialization-safe",
      "file": "tools/demo/27-deserialization-safe.py",
      "expected": {
        "verdict": "clean-or-advisory",
        "must_not_include_issue_ids": ["owlvex.issue.insecure_deserialization.001"]
      }
    }
  ]
}
