{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://owlvex.io/schemas/policy-pack.schema.v1.json",
  "title": "Owlvex Policy Pack v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "templates"
  ],
  "properties": {
    "schema_version": {
      "const": "owlvex.policy-pack.v1"
    },
    "pack_id": {
      "type": "string",
      "pattern": "^owlvex\\.[a-z0-9.-]+\\.[0-9]{4}\\.[0-9]+$"
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schema_version",
          "id",
          "name",
          "description",
          "policy",
          "rationale",
          "references",
          "provenance"
        ],
        "properties": {
          "schema_version": {
            "const": "owlvex.policy-template.v1"
          },
          "id": {
            "type": "string",
            "pattern": "^owlvex\\.policy\\.[a-z0-9_]+\\.[0-9]{3}$"
          },
          "name": {
            "type": "string",
            "minLength": 3
          },
          "description": {
            "type": "string",
            "minLength": 12
          },
          "policy": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "policy",
              "conditions"
            ],
            "properties": {
              "policy": {
                "type": "string",
                "enum": [
                  "allow",
                  "warn",
                  "block"
                ]
              },
              "conditions": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "issue_ids": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "pattern": "^owlvex\\.issue\\.[a-z0-9_]+\\.[0-9]{3}$"
                    }
                  },
                  "severity": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "INFO",
                        "LOW",
                        "MEDIUM",
                        "HIGH",
                        "CRITICAL"
                      ]
                    }
                  },
                  "minimum_severity": {
                    "type": "string",
                    "enum": [
                      "INFO",
                      "LOW",
                      "MEDIUM",
                      "HIGH",
                      "CRITICAL"
                    ]
                  }
                }
              }
            }
          },
          "rationale": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 12
            }
          },
          "recommended_workflow": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 8
            }
          },
          "references": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "label",
                "kind"
              ],
              "properties": {
                "label": {
                  "type": "string",
                  "minLength": 3
                },
                "kind": {
                  "type": "string",
                  "enum": [
                    "official-doc",
                    "taxonomy",
                    "standard",
                    "cheat-sheet",
                    "vendor-doc",
                    "internal-review",
                    "other"
                  ]
                },
                "publisher": {
                  "type": "string"
                },
                "document_id": {
                  "type": "string"
                },
                "section": {
                  "type": "string"
                }
              }
            }
          },
          "provenance": {
            "$ref": "https://owlvex.io/schemas/provenance.schema.v1.json"
          }
        }
      }
    }
  }
}
