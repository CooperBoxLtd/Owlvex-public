{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://owlvex.io/schemas/provenance.schema.v1.json",
  "title": "Owlvex Grounded Data Provenance v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_type",
    "curation_method",
    "review_status",
    "sources"
  ],
  "properties": {
    "source_type": {
      "type": "string",
      "enum": ["official", "curated", "hybrid", "generated"]
    },
    "curation_method": {
      "type": "string",
      "enum": ["manual", "derived", "ai-assisted-reviewed", "imported-reviewed", "unknown"]
    },
    "review_status": {
      "type": "string",
      "enum": ["draft", "needs-review", "reviewed", "verified"]
    },
    "reviewed_by": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_verified_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "kind"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": ["official-doc", "taxonomy", "standard", "cheat-sheet", "vendor-doc", "internal-review", "other"]
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "publisher": {
            "type": "string"
          },
          "document_id": {
            "type": "string"
          },
          "section": {
            "type": "string"
          }
        }
      }
    }
  }
}
