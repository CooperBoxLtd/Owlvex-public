{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://owlvex.io/schemas/remediation-pack.schema.v1.json",
  "title": "Owlvex Remediation Pack v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "const": "owlvex.remediation-pack.v1"
    },
    "pack_id": {
      "type": "string",
      "pattern": "^owlvex\\.[a-z0-9.-]+\\.[0-9]{4}\\.[0-9]+$"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schema_version",
          "id",
          "issue_id",
          "title",
          "canonical_fix_summary",
          "framework_variants",
          "validation_steps",
          "unsafe_alternatives",
          "references",
          "provenance"
        ],
        "properties": {
          "schema_version": {
            "const": "owlvex.remediation.v1"
          },
          "id": {
            "type": "string",
            "pattern": "^owlvex\\.remediation\\.[a-z0-9_]+\\.[0-9]{3}$"
          },
          "issue_id": {
            "type": "string",
            "pattern": "^owlvex\\.issue\\.[a-z0-9_]+\\.[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 3
          },
          "canonical_fix_summary": {
            "type": "string",
            "minLength": 24
          },
          "framework_variants": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "framework",
                "summary",
                "recommended_actions"
              ],
              "properties": {
                "framework": {
                  "type": "string",
                  "minLength": 2
                },
                "summary": {
                  "type": "string",
                  "minLength": 16
                },
                "recommended_actions": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 8
                  }
                }
              }
            }
          },
          "validation_steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 8
            }
          },
          "unsafe_alternatives": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 8
            }
          },
          "references": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "label",
                "kind"
              ],
              "properties": {
                "label": {
                  "type": "string",
                  "minLength": 3
                },
                "kind": {
                  "type": "string",
                  "enum": [
                    "official-doc",
                    "taxonomy",
                    "standard",
                    "cheat-sheet",
                    "vendor-doc",
                    "internal-review",
                    "other"
                  ]
                },
                "publisher": {
                  "type": "string"
                },
                "document_id": {
                  "type": "string"
                },
                "section": {
                  "type": "string"
                }
              }
            }
          },
          "provenance": {
            "$ref": "https://owlvex.io/schemas/provenance.schema.v1.json"
          }
        }
      }
    }
  }
}
