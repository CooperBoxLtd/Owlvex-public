{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "5696676337197287227"
    }
  },
  "parameters": {
    "environment": {
      "type": "string",
      "defaultValue": "production",
      "metadata": {
        "description": "Environment tag — prod only here"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region"
      }
    },
    "prefix": {
      "type": "string",
      "defaultValue": "owlvex",
      "metadata": {
        "description": "Short prefix used in all resource names"
      }
    },
    "imageTag": {
      "type": "string",
      "defaultValue": "latest",
      "metadata": {
        "description": "Container image tag to deploy"
      }
    },
    "postgresAdminUser": {
      "type": "string",
      "defaultValue": "owlvex",
      "metadata": {
        "description": "PostgreSQL admin username"
      }
    },
    "postgresAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "PostgreSQL admin password"
      }
    },
    "postgresDbName": {
      "type": "string",
      "defaultValue": "owlvex",
      "metadata": {
        "description": "PostgreSQL database name"
      }
    },
    "secretKey": {
      "type": "securestring"
    },
    "adminKey": {
      "type": "securestring"
    },
    "stripeSecretKey": {
      "type": "securestring",
      "defaultValue": ""
    },
    "stripeWebhookSecret": {
      "type": "securestring",
      "defaultValue": ""
    },
    "sendgridApiKey": {
      "type": "securestring",
      "defaultValue": ""
    },
    "stripePriceDeveloperMonthly": {
      "type": "string",
      "defaultValue": ""
    },
    "stripePriceDeveloperAnnual": {
      "type": "string",
      "defaultValue": ""
    },
    "stripePriceTeamMonthly": {
      "type": "string",
      "defaultValue": ""
    },
    "stripePriceTeamAnnual": {
      "type": "string",
      "defaultValue": ""
    },
    "fromEmail": {
      "type": "string",
      "defaultValue": "noreply@owlvex.io"
    }
  },
  "variables": {
    "acrName": "[format('{0}registry', parameters('prefix'))]",
    "appServicePlanName": "[format('{0}-plan', parameters('prefix'))]",
    "webAppName": "[format('{0}-api', parameters('prefix'))]",
    "appInsightsName": "[format('{0}-appi', parameters('prefix'))]",
    "appInsightsConnectionStringSetting": "APPLICATIONINSIGHTS_CONNECTION_STRING"
  },
  "resources": [
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-07-01",
      "name": "[variables('acrName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Basic"
      },
      "properties": {
        "adminUserEnabled": true
      },
      "tags": {
        "environment": "[parameters('environment')]"
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[format('{0}-logs', parameters('prefix'))]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      },
      "tags": {
        "environment": "[parameters('environment')]"
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('appInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-logs', parameters('prefix')))]"
      },
      "tags": {
        "environment": "[parameters('environment')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-logs', parameters('prefix')))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}-kv', parameters('prefix'))]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "tenantId": "[subscription().tenantId]",
        "enableRbacAuthorization": true,
        "softDeleteRetentionInDays": 7,
        "enabledForTemplateDeployment": false
      },
      "tags": {
        "environment": "[parameters('environment')]"
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', format('{0}-kv', parameters('prefix')), 'secret-key')]",
      "properties": {
        "value": "[parameters('secretKey')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', format('{0}-kv', parameters('prefix')))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', format('{0}-kv', parameters('prefix')), 'admin-key')]",
      "properties": {
        "value": "[parameters('adminKey')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', format('{0}-kv', parameters('prefix')))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', format('{0}-kv', parameters('prefix')), 'stripe-secret-key')]",
      "properties": {
        "value": "[parameters('stripeSecretKey')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', format('{0}-kv', parameters('prefix')))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', format('{0}-kv', parameters('prefix')), 'stripe-webhook-secret')]",
      "properties": {
        "value": "[parameters('stripeWebhookSecret')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', format('{0}-kv', parameters('prefix')))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', format('{0}-kv', parameters('prefix')), 'sendgrid-api-key')]",
      "properties": {
        "value": "[parameters('sendgridApiKey')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', format('{0}-kv', parameters('prefix')))]"
      ]
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers",
      "apiVersion": "2023-06-01-preview",
      "name": "[format('{0}-db', parameters('prefix'))]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_B1ms",
        "tier": "Burstable"
      },
      "properties": {
        "administratorLogin": "[parameters('postgresAdminUser')]",
        "administratorLoginPassword": "[parameters('postgresAdminPassword')]",
        "storage": {
          "storageSizeGB": 32
        },
        "backup": {
          "backupRetentionDays": 7,
          "geoRedundantBackup": "Disabled"
        },
        "highAvailability": {
          "mode": "Disabled"
        },
        "version": "16"
      },
      "tags": {
        "environment": "[parameters('environment')]"
      }
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
      "apiVersion": "2023-06-01-preview",
      "name": "[format('{0}/{1}', format('{0}-db', parameters('prefix')), parameters('postgresDbName'))]",
      "properties": {
        "charset": "UTF8",
        "collation": "en_US.utf8"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', format('{0}-db', parameters('prefix')))]"
      ]
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/firewallRules",
      "apiVersion": "2023-06-01-preview",
      "name": "[format('{0}/{1}', format('{0}-db', parameters('prefix')), 'AllowAzureServices')]",
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', format('{0}-db', parameters('prefix')))]"
      ]
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[variables('appServicePlanName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "B1",
        "tier": "Basic",
        "size": "B1",
        "family": "B",
        "capacity": 1
      },
      "kind": "linux",
      "properties": {
        "reserved": true
      },
      "tags": {
        "environment": "[parameters('environment')]"
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[variables('webAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux,container",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "[format('DOCKER|{0}/owlvex-api:{1}', reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').loginServer, parameters('imageTag'))]",
          "appSettings": [
            {
              "name": "DOCKER_REGISTRY_SERVER_URL",
              "value": "[format('https://{0}', reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').loginServer)]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_USERNAME",
              "value": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').username]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_PASSWORD",
              "value": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').passwords[0].value]"
            },
            {
              "name": "WEBSITES_PORT",
              "value": "8000"
            },
            {
              "name": "WEBSITES_ENABLE_APP_SERVICE_STORAGE",
              "value": "false"
            },
            {
              "name": "DATABASE_URL",
              "value": "[format('postgresql+asyncpg://{0}:{1}@{2}:5432/{3}?ssl=require', parameters('postgresAdminUser'), parameters('postgresAdminPassword'), reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', format('{0}-db', parameters('prefix'))), '2023-06-01-preview').fullyQualifiedDomainName, parameters('postgresDbName'))]"
            },
            {
              "name": "SECRET_KEY",
              "value": "[parameters('secretKey')]"
            },
            {
              "name": "ADMIN_KEY",
              "value": "[parameters('adminKey')]"
            },
            {
              "name": "STRIPE_SECRET_KEY",
              "value": "[parameters('stripeSecretKey')]"
            },
            {
              "name": "STRIPE_WEBHOOK_SECRET",
              "value": "[parameters('stripeWebhookSecret')]"
            },
            {
              "name": "SENDGRID_API_KEY",
              "value": "[parameters('sendgridApiKey')]"
            },
            {
              "name": "STRIPE_PRICE_DEVELOPER_MONTHLY",
              "value": "[parameters('stripePriceDeveloperMonthly')]"
            },
            {
              "name": "STRIPE_PRICE_DEVELOPER_ANNUAL",
              "value": "[parameters('stripePriceDeveloperAnnual')]"
            },
            {
              "name": "STRIPE_PRICE_TEAM_MONTHLY",
              "value": "[parameters('stripePriceTeamMonthly')]"
            },
            {
              "name": "STRIPE_PRICE_TEAM_ANNUAL",
              "value": "[parameters('stripePriceTeamAnnual')]"
            },
            {
              "name": "FROM_EMAIL",
              "value": "[parameters('fromEmail')]"
            },
            {
              "name": "ENVIRONMENT",
              "value": "production"
            },
            {
              "name": "[variables('appInsightsConnectionStringSetting')]",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]"
            }
          ],
          "healthCheckPath": "/health",
          "alwaysOn": true,
          "acrUseManagedIdentityCreds": false,
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2",
          "http20Enabled": true
        }
      },
      "tags": {
        "environment": "[parameters('environment')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrName'))]",
        "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]",
        "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', format('{0}-db', parameters('prefix')))]"
      ]
    }
  ],
  "outputs": {
    "apiUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', variables('webAppName')), '2023-12-01').defaultHostName)]"
    },
    "acrLoginServer": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').loginServer]"
    },
    "postgresHost": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', format('{0}-db', parameters('prefix'))), '2023-06-01-preview').fullyQualifiedDomainName]"
    },
    "keyVaultName": {
      "type": "string",
      "value": "[format('{0}-kv', parameters('prefix'))]"
    },
    "webAppName": {
      "type": "string",
      "value": "[variables('webAppName')]"
    }
  }
}