# ============================================================
# infra/.env.azure.example — production environment variables
#
# Legacy compatibility alias for the production environment file.
#
# Preferred pattern now:
#   cp infra/.env.prod.example infra/.env.prod
#   bash infra/deploy-prod.sh
#
# Backward-compatible pattern:
#   cp infra/.env.azure.example infra/.env.azure
#   source infra/.env.azure
#   bash infra/deploy.sh
#
# NEVER commit infra/.env.azure or infra/.env.prod to git.
# ============================================================

# ── Deployment target ──────────────────────────────────────

RESOURCE_GROUP=owlvex-prd
LOCATION=uksouth
PREFIX=owlvex

# ── Database ───────────────────────────────────────────────
# Must be 8–128 characters, include uppercase, lowercase, and digit/symbol.

POSTGRES_ADMIN_PASSWORD=change-me-strong-password

# ── API security ───────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=change-me-64-char-random-string
ADMIN_KEY=change-me-another-64-char-random-string

# ── Stripe ─────────────────────────────────────────────────
# Leave empty until Stripe is wired up. API starts without these.

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

STRIPE_PRICE_DEVELOPER_MONTHLY=price_...
STRIPE_PRICE_DEVELOPER_ANNUAL=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_ANNUAL=price_...

# ── Email ──────────────────────────────────────────────────

SENDGRID_API_KEY=SG....
FROM_EMAIL=noreply@owlvex.io
