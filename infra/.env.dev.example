# ============================================================
# infra/.env.dev.example
#
# Development control-plane environment.
# Intended for ml30 or another non-production host.
#
# Copy to infra/.env.dev, edit values, then:
#   source infra/.env.dev
# ============================================================

RESOURCE_GROUP=owlvex-dev
LOCATION=westeurope
PREFIX=owlvexdev

# These values are only needed if you choose to exercise the Azure
# deploy path for a dev-like environment. They are not required for
# the normal docker-compose flow on ml30.

POSTGRES_ADMIN_PASSWORD=change-me-dev-password
SECRET_KEY=change-me-dev-secret
ADMIN_KEY=change-me-dev-admin-key

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_DEVELOPER_MONTHLY=
STRIPE_PRICE_DEVELOPER_ANNUAL=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_ANNUAL=
SENDGRID_API_KEY=
FROM_EMAIL=noreply@owlvex.io
