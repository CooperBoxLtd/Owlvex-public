# ============================================================
# infra/.env.dev.example
#
# Development Azure control-plane environment.
#
# Copy to infra/.env.dev, edit values, then:
#   az login
#   az account set --subscription c0b31fc1-52d0-4339-96ee-9915e4dfe3c4
#   bash infra/deploy-dev.sh
# ============================================================

RESOURCE_GROUP=owlvex-dev
LOCATION=uksouth
PREFIX=owlvexdev

# Required for the hosted Azure dev environment.
# Keep these values separate from production.

POSTGRES_ADMIN_PASSWORD=change-me-dev-password
SECRET_KEY=change-me-dev-secret
ADMIN_KEY=change-me-dev-admin-key

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_DEVELOPER_MONTHLY=
STRIPE_PRICE_DEVELOPER_ANNUAL=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_ANNUAL=
SENDGRID_API_KEY=
FROM_EMAIL=noreply@owlvex.io
