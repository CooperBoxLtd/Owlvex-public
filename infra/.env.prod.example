# ============================================================
# infra/.env.prod.example
#
# Production control-plane environment.
#
# Copy to infra/.env.prod, edit values, then:
#   az login
#   az account set --subscription c0b31fc1-52d0-4339-96ee-9915e4dfe3c4
#   bash infra/deploy-prod.sh
#
# NEVER commit infra/.env.prod to git.
# ============================================================

RESOURCE_GROUP=owlvex-prd
LOCATION=uksouth
PREFIX=owlvex
APP_NAME=owlvex-api
ACR_NAME=owlvexregistry
PG_SERVER_NAME=owlvex-dbserver
ACR_USE_MANAGED_IDENTITY=1

POSTGRES_ADMIN_PASSWORD=change-me-strong-password
SECRET_KEY=change-me-64-char-random-string
ADMIN_KEY=change-me-another-64-char-random-string

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

STRIPE_PRICE_DEVELOPER_MONTHLY=
STRIPE_PRICE_DEVELOPER_ANNUAL=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_ANNUAL=

SENDGRID_API_KEY=
# Must be a SendGrid-verified sender identity or verified domain sender.
FROM_EMAIL=noreply@owlvex.io
